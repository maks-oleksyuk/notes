{
  "homepage": "https://maks-oleksyuk.github.io/notes",
  "license": "WTFPL",
  "author": {
    "name": "Maks Oleksyuk",
    "url": "https://github.com/maks-oleksyuk"
  },
  "scripts": {
    "lint": "pnpm run stylelint; pnpm run prettier",
    "lint:fix": "pnpm run stylelint:fix; pnpm run prettier:fix",
    "stylelint": "stylelint ./styles",
    "stylelint:fix": "stylelint ./styles --fix",
    "prettier": "prettier ./styles -c --cache",
    "prettier:fix": "prettier ./styles -w"
  },
  "devDependencies": {
    "prettier": "^3.0.3",
    "stylelint": "^15.11.0",
    "stylelint-config-standard-scss": "^11.0.0",
    "stylelint-order": "^6.0.3",
    "stylelint-scss": "^5.3.0"
  },
  "engines": {
    "pnpm": ">=8",
    "node": ">=18"
  },
  "prettier": {
    "singleQuote": true,
    "bracketSameLine": true
  },
  "stylelint": {
    "extends": [
      "../../web/core/.stylelintrc.json",
      "stylelint-config-standard-scss"
    ],
    "plugins": [
      "stylelint-scss"
    ]
  }
}
