{
  "homepage": "https://maks-oleksyuk.github.io/notes",
  "license": "WTFPL",
  "type": "module",
  "author": {
    "name": "Maks Oleksyuk",
    "url": "https://github.com/maks-oleksyuk"
  },
  "scripts": {
    "dev": "webpack --progress --watch",
    "build": "webpack --progress",
    "lint": "run-p -cls lint:js lint:style lint:format",
    "lint:fix": "run-p -cls lint:*:fix",
    "lint:js": "eslint js --no-error-on-unmatched-pattern --color",
    "lint:js:fix": "eslint js --no-error-on-unmatched-pattern --fix",
    "lint:style": "stylelint styles --aei --cache --cache-location node_modules/.cache/stylelint/ --color",
    "lint:style:fix": "stylelint styles --aei --cache --fix",
    "lint:format": "prettier styles js -c --cache --no-error-on-unmatched-pattern --color",
    "lint:format:fix": "prettier styles js -wl --cache --no-error-on-unmatched-pattern",
    "postinstall": "sed -i '/\"airbnb-base\",/d;/^ *$/d' ../../web/core/.eslintrc.json || true"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.16",
    "clean-webpack-plugin": "^4.0.0",
    "css-loader": "^6.8.1",
    "eslint": "^8.55.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.29.0",
    "eslint-plugin-jquery": "^1.5.1",
    "eslint-plugin-prettier": "^5.0.1",
    "eslint-plugin-yml": "^1.10.0",
    "glob": "^10.3.10",
    "mini-css-extract-plugin": "^2.7.6",
    "npm-run-all": "^4.1.5",
    "postcss-loader": "^7.3.3",
    "postcss-perfectionist": "^2.3.9",
    "postcss-rtlcss": "^4.0.9",
    "prettier": "^3.1.0",
    "sass": "^1.69.5",
    "sass-loader": "^13.3.2",
    "stylelint": "^15.11.0",
    "stylelint-config-standard-scss": "^11.1.0",
    "stylelint-order": "^6.0.4",
    "stylelint-scss": "^5.3.1",
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.4",
    "webpack-remove-empty-scripts": "^1.0.4"
  },
  "packageManager": "pnpm@8.12.0+",
  "engines": {
    "pnpm": ">=8",
    "node": ">=18"
  },
  "eslintConfig": {
    "extends": [
      "../../web/core/.eslintrc.passing.json",
      "airbnb-base"
    ]
  },
  "prettier": {
    "singleQuote": true,
    "bracketSameLine": true
  },
  "stylelint": {
    "extends": [
      "../../web/core/.stylelintrc.json",
      "stylelint-config-standard-scss"
    ],
    "plugins": [
      "stylelint-scss"
    ]
  }
}
